{
  "manifest_version": 3,
  "name": "Zoom Toggle",
  "version": "1.0",
  "description": "Click to zoom to a custom level, click again to reset to 100%.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Zoom Toggle"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Command+Shift+Z",
        "default": "Ctrl+Shift+Z"
      },
      "description": "Toggle zoom level"
    }
  }
}
